{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noted",
  "version": "0.2.1",
  "identifier": "com.khurram.noted",
  "build": {
    "beforeDevCommand": "npm run build:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "noted",
        "width": 340,
        "height": 440,
        "minWidth": 340,
        "minHeight": 440,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/khurrambhutto/noted/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1NzExOTVENzE0NkQ4MzgKUldRNDJFWnhYUmx4TmU3ekF2czU1UXpGOURxN29GUml5UFJvUnlUU3FpSXhtZUUwejdzMlZLcEIK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/noted-toggle": "../scripts/noted-toggle"
        }
      },
      "rpm": {
        "files": {
          "/usr/bin/noted-toggle": "../scripts/noted-toggle"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
